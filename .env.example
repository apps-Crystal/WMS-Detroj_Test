# ============================================================
# COPY THIS FILE to .env.local for local development
# For Vercel: Add these as Environment Variables in your
# Vercel Project → Settings → Environment Variables
# ============================================================

# NextAuth — REQUIRED
# Set NEXTAUTH_URL to your Vercel deployment URL (e.g. https://your-app.vercel.app)
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=your_random_secret_here_min_32_chars

# Google Sheet ID (from the URL of your spreadsheet)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Drive Folder ID (for photo uploads)
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Google Apps Script Web App URL (Deploy → New Deployment → Web App)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
